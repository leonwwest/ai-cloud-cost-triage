{
  "tag-pair": true,
  "tagname-lowercase": true,
  "attr-lowercase": true,
  "attr-value-double-quotes": true,
  "doctype-first": true,
  "id-unique": true,
  "src-not-empty": true,
  "title-require": true,
  "attr-no-duplication": true,
  "spec-char-escape": false,
  "empty-tag-not-self-closing": false,
  "head-script-disabled": false,
  "href-abs-or-rel": false,
  "img-alt-require": true
}
